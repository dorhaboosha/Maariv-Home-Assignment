# Dependencies
frontend/node_modules/
/node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Environment variables
frontend/.env.local
frontend/.env.*.local

# Next.js cache
frontend/.next/cache/


# ─── General ────────────────────────────────────────────────────────────────────

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
*.swp
*.swo
