# ─── ASP.NET Core / .NET ───────────────────────────────────────────────────────

# Build outputs
backend/bin/
backend/obj/

# User-specific Visual Studio files
*.user
*.suo
.vs/

# Rider IDE
.idea/

# NuGet packages (restored automatically)
backend/*.nupkg

# Publish output
backend/publish/

# Environment overrides
backend/appsettings.*.local.json


